# 로컬 개발용 환경변수 — 복사 후 .env.local로 저장

# 백엔드 URL (로컬에서 Koyeb 직접 호출)
NEXT_PUBLIC_API_URL=https://deliberate-lenette-coggiri-5ee7b85e.koyeb.app

# 카카오 OAuth (카카오 개발자 콘솔에서 복사)
# Web 플랫폼에 http://localhost:3000 추가 필요
# Redirect URI에 http://localhost:3000/auth/kakao/callback 추가 필요
NEXT_PUBLIC_KAKAO_CLIENT_ID=<카카오_REST_API_키>
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# 로컬에서는 카카오 로그인 대신 관리자 로그인 사용 가능:
#   http://localhost:3000/auth/admin-login
#   (ID/PW는 Koyeb 환경변수 DASHBOARD_ADMIN_USERNAME/PASSWORD 기준)
