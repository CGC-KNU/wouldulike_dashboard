# 백엔드 API URL
NEXT_PUBLIC_API_URL=https://your-backend.koyeb.app

# 카카오 로그인
NEXT_PUBLIC_KAKAO_CLIENT_ID=your_kakao_client_id
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# Apple 로그인
NEXT_PUBLIC_APPLE_CLIENT_ID=com.coggiri.wouldulike0117
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback

# 앱 → 웹 자동로그인 시크릿 (백엔드와 공유)
APP_WEBVIEW_SECRET=your_secret_key
